# 대회목록 시트 ID
CONTEST_LIST_SHEET_ID=1bRclkuN8fuSfhoSrRUEtBjPPx6TePofxojE72qHV6iU

# 대회목록 탭의 gid (Google Sheets URL의 #gid=... 부분)
CONTEST_LIST_SHEET_GID=2102151233

# 캐시 TTL (초). Design §4.4 — 5초 권장
SHEETS_CACHE_TTL_SECONDS=5

# 참고: gviz CSV 엔드포인트를 사용하므로 GOOGLE_SHEETS_API_KEY는 불필요.
# 모든 시트가 "링크가 있는 모든 사용자: 뷰어" 이상으로 공유되어 있어야 함.

# ─── Brevo (참가자 등록 확인 메일) ─────────────────────────────────────────
# https://app.brevo.com/settings/keys/api 에서 발급. 빈 값이면 메일 발송이 자동으로 비활성화.
BREVO_API_KEY=
# 발신자 주소. Brevo 대시보드 → Senders 에서 검증 완료된 이메일이어야 함.
# (개인 Gmail 도 검증만 하면 사용 가능. 도메인 인증 불필요.)
BREVO_FROM_EMAIL=
# 선택. 발신자 표시 이름. 미설정 시 "JNJ JOIN".
BREVO_FROM_NAME=JNJ JOIN
